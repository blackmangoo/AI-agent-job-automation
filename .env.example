# ============================================
# AI Job Application Agent — Environment Config
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# GitHub Personal Access Token (for git_manager.py)
# Scopes needed: repo
GITHUB_TOKEN=ghp_your_github_token_here

# Google Sheets — Spreadsheet ID
# (the long string in the Google Sheets URL between /d/ and /edit)
# Leave blank to auto-create a new sheet on first run
GOOGLE_SHEETS_ID=

# Google Sheets — Path to service account JSON key
GOOGLE_SHEETS_CREDENTIALS=./credentials/google_sheets_key.json

# Browser data directory for persistent sessions
BROWSER_DATA_DIR=./browser_data
